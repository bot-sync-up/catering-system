{
  "name": "catering-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "מערכת קייטרינג מאוחדת - מונורפו pnpm + turbo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @catering/db migrate",
    "db:seed": "pnpm --filter @catering/db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "import:worktrees": "bash ./scripts/import-worktrees.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "eslint": "^9.16.0"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {}
  }
}
