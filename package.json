{
  "name": "aneh-hashoel-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the 'Aneh et HaShoel' platform.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:generate": "npm -w @aneh-hashoel/db run generate",
    "db:migrate": "npm -w @aneh-hashoel/db run migrate:deploy",
    "db:seed": "npm -w @aneh-hashoel/db run db:seed"
  }
}
