{
  "name": "field-ops-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm --workspace apps/mobile run start",
    "mobile:android": "npm --workspace apps/mobile run android",
    "mobile:ios": "npm --workspace apps/mobile run ios",
    "lint": "npm --workspace apps/mobile run lint",
    "typecheck": "npm --workspace apps/mobile run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
