// מערכת ניהול הזמנות — סכמה
// 3 סוגי הזמנות: אירוע חד-פעמי, מנוי קבוע, מנוי חודשי
// Flow: לקוח -> מנהל מאשר -> אישור -> הצ"מ + חשבונית + משימות מטבח + משלוח

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum OrderType {
  ONE_TIME_EVENT      // אירוע חד-פעמי
  RECURRING_PLAN      // מנוי קבוע (כל שבוע / יומי)
  MONTHLY_SUBSCRIPTION // מנוי חודשי
}

enum OrderStatus {
  DRAFT        // טיוטה — נוצר ע"י לקוח/סוכן, טרם הוגש
  PENDING      // ממתין לאישור מנהל
  APPROVED     // אושר ע"י מנהל
  PREPARING    // במטבח/בהכנה
  DELIVERING   // יצא למשלוח
  COMPLETED    // הושלם
  CANCELLED    // בוטל
  WAITLISTED   // ברשימת המתנה (אין מקום באירוע/מסלול)
}

enum Channel {
  PORTAL       // פורטל לקוח
  PHONE        // הזמנה טלפונית (קלידן)
  WHATSAPP     // ווטסאפ
  AGENT        // סוכן שטח
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  CHECK        // צ'ק (תומך ב-refund מיוחד)
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

enum KitchenTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  DELIVERED
  FAILED
}

enum SubscriptionFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id             String         @id @default(cuid())
  fullName       String         // שם מלא
  phone          String         @unique
  email          String?        @unique
  address        String?
  city           String?
  notes          String?        // הערות פנימיות
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  orders         Order[]
  subscriptions  Subscription[]
  waitlistEntries Waitlist[]
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique // מספר הזמנה לתצוגה
  type            OrderType
  status          OrderStatus   @default(DRAFT)
  channel         Channel
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])

  // לאירוע חד-פעמי
  eventDate       DateTime?     // תאריך האירוע
  eventLocation   String?
  guestCount      Int?          // מספר אורחים (לחישוב waitlist)

  // למנויים — קישור למנוי
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  // סכומים
  subtotal        Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float         @default(0)

  // הערות לקוח / מנהל
  customerNotes   String?
  internalNotes   String?

  // אישור מנהל
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?

  // ביטול
  cancelledAt     DateTime?
  cancellationReason String?
  cancellationPolicyId String?
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])
  refundAmount    Float?        // סכום החזר בפועל

  // החלפה (swap) — אם הוחלף בהזמנה אחרת
  swappedToOrderId String?      @unique
  swappedFromOrderId String?    @unique
  swappedTo       Order?        @relation("OrderSwap", fields: [swappedToOrderId], references: [id])
  swappedFrom     Order?        @relation("OrderSwap")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           OrderItem[]
  payments        Payment[]
  invoice         Invoice?
  shipmentDoc     ShipmentDoc?  // הצ"מ — הודעת משלוח
  kitchenTasks    KitchenTask[]
  delivery        Delivery?
  statusHistory   StatusHistoryEntry[]
  waitlistEntries Waitlist[]

  @@index([status])
  @@index([type])
  @@index([eventDate])
  @@index([customerId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productSku  String
  productName String   // snapshot
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  // למשימות מטבח
  kitchenInstructions String?

  createdAt   DateTime @default(now())
}

// ============================================================
// SUBSCRIPTIONS (למנוי קבוע / חודשי)
// ============================================================

model Subscription {
  id            String                 @id @default(cuid())
  customerId    String
  customer      Customer               @relation(fields: [customerId], references: [id])
  frequency     SubscriptionFrequency
  startDate     DateTime
  endDate       DateTime?
  active        Boolean                @default(true)
  pricePerCycle Float
  notes         String?

  // ימים בשבוע — bitmask (1=ראשון, 2=שני, 4=שלישי, ...) למנוי שבועי
  weekDaysMask  Int                    @default(0)

  // ביום בחודש — למנוי חודשי
  dayOfMonth    Int?

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  orders        Order[]
}

// ============================================================
// CANCELLATION POLICY
// ============================================================
// מדיניות ביטול: אחוזי החזר לפי קרבה לתאריך האירוע
// לדוגמה:
//   > 30 יום מראש -> 100% החזר
//   14-30 יום    -> 75%
//   7-14 יום     -> 50%
//   2-7 ימים     -> 25%
//   < 48 שעות    -> 0%

model CancellationPolicy {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  active      Boolean             @default(true)
  tiers       CancellationTier[]
  orders      Order[]

  createdAt   DateTime            @default(now())
}

model CancellationTier {
  id            String             @id @default(cuid())
  policyId      String
  policy        CancellationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  // טווח שעות לפני האירוע (כולל min, לא כולל max)
  hoursBeforeMin Int               // לדוגמה: 0
  hoursBeforeMax Int?              // null = אין מקסימום (כל הזמן שמעל min)
  refundPercent  Int               // 0..100

  @@index([policyId])
}

// ============================================================
// PAYMENTS / CHECK REFUND
// ============================================================

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  amount        Float
  status        PaymentStatus @default(PENDING)
  reference     String?       // אסמכתא / מספר עסקה

  // לצ'ק
  checkNumber   String?
  checkBank     String?
  checkBranch   String?
  checkDueDate  DateTime?     // תאריך פירעון

  // החזר
  refundAmount  Float?
  refundedAt    DateTime?
  refundMethod  PaymentMethod? // יכול להיות שונה מהתשלום (לדוגמה — צ'ק שולם, החזר במזומן)
  refundCheckNumber String?    // אם החזר בצ'ק

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

// ============================================================
// INVOICE / SHIPMENT DOC ("הצ"מ")
// ============================================================

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  totalAmount   Float
  taxAmount     Float
  pdfUrl        String?
}

model ShipmentDoc {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  docNumber    String   @unique // מספר הצ"מ
  issuedAt     DateTime @default(now())
  pdfUrl       String?
}

// ============================================================
// KITCHEN TASKS / DELIVERY
// ============================================================

model KitchenTask {
  id           String            @id @default(cuid())
  orderId      String
  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title        String            // לדוגמה: "הכנת 50 מנות חמין"
  description  String?
  status       KitchenTaskStatus @default(TODO)
  assignedTo   String?           // שף / עובד מטבח
  dueAt        DateTime?
  completedAt  DateTime?

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([orderId])
  @@index([status])
}

model Delivery {
  id           String          @id @default(cuid())
  orderId      String          @unique
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status       DeliveryStatus  @default(PENDING)
  driverName   String?
  driverPhone  String?
  scheduledAt  DateTime?
  deliveredAt  DateTime?
  address      String
  city         String?
  notes        String?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// ============================================================
// WAITLIST
// ============================================================

model Waitlist {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  orderId     String?  // ההזמנה שיצרה את הרישום (אופציונלי — אם נוצר מהזמנה ישירה)
  order       Order?   @relation(fields: [orderId], references: [id])

  // עבור איזה אירוע / תאריך
  eventDate   DateTime
  eventName   String?
  guestCount  Int      @default(1)

  // סדר תור
  position    Int
  notified   Boolean  @default(false)
  promoted   Boolean  @default(false) // האם קודם להזמנה רגילה
  promotedAt DateTime?

  createdAt  DateTime @default(now())

  @@index([eventDate])
  @@index([promoted])
}

// ============================================================
// AUDIT — היסטוריית סטטוסים
// ============================================================

model StatusHistoryEntry {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  reason     String?
  actor      String?      // user id / "system"
  createdAt  DateTime     @default(now())

  @@index([orderId])
}
