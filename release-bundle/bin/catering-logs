#!/usr/bin/env bash
# catering-logs — צפיה בלוגים
# שימוש: catering-logs [service] [-n LINES] [-f]
source "$(dirname "$0")/_common.sh"

APP_DIR="$(find_app_dir)"
cd "$APP_DIR"

SERVICE=""
LINES=100
FOLLOW=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n) LINES="$2"; shift 2 ;;
    --no-follow) FOLLOW=0; shift ;;
    -f) FOLLOW=1; shift ;;
    dev|app|web|api|postgres|redis|worker|nginx)
      SERVICE="$1"; shift ;;
    *) SERVICE="$1"; shift ;;
  esac
done

# dev server log (לא ב-docker)
if [ "$SERVICE" = "dev" ]; then
  if [ -f .yolo-logs/dev.log ]; then
    if [ "$FOLLOW" -eq 1 ]; then
      tail -n "$LINES" -f .yolo-logs/dev.log
    else
      tail -n "$LINES" .yolo-logs/dev.log
    fi
  else
    err "אין קובץ .yolo-logs/dev.log"
  fi
  exit 0
fi

require_docker
COMPOSE="$(find_compose_file "$APP_DIR")"
[ -z "$COMPOSE" ] && { err "לא נמצא compose"; exit 1; }

FLAGS=(--tail="$LINES")
[ "$FOLLOW" -eq 1 ] && FLAGS+=(-f)

if [ -n "$SERVICE" ]; then
  docker compose -f "$COMPOSE" logs "${FLAGS[@]}" "$SERVICE"
else
  docker compose -f "$COMPOSE" logs "${FLAGS[@]}"
fi
