# .env.dev.example
# העתיקו לקובץ .env בשורש המונורפו:
#   cp dev-bootstrap/.env.dev.example .env
#
# כל הערכים כאן הם לפיתוח לוקאלי בלבד. אסור להעתיק לייצור!
# סודות אמיתיים לייצור מנוהלים דרך .env.prod / vault / secret manager.

# ============================================================
# בסיסי
# ============================================================
NODE_ENV=development
LOG_LEVEL=debug
APP_NAME=catering-taamim
APP_VERSION=0.1.0
TZ=Asia/Jerusalem

# ============================================================
# Database (Postgres 16 מקומי דרך Docker)
# ============================================================
DATABASE_URL=postgresql://catering:dev_password_change_in_prod@localhost:5432/catering_dev?schema=public
SHADOW_DATABASE_URL=postgresql://catering:dev_password_change_in_prod@localhost:5432/catering_shadow?schema=public
TEST_DATABASE_URL=postgresql://catering:dev_password_change_in_prod@localhost:5432/catering_test?schema=public
DB_POOL_MAX=20
DB_POOL_MIN=2

# ============================================================
# Redis (cache, sessions, BullMQ)
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# ============================================================
# Auth / JWT
# ============================================================
JWT_SECRET=dev-only-jwt-secret-change-in-prod-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
SESSION_SECRET=dev-only-session-secret-change-in-prod
COOKIE_DOMAIN=localhost

# ============================================================
# Public URLs
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
GATEWAY_URL=http://localhost:4000

# ============================================================
# CARDcom — שערי תשלום (sandbox)
# ============================================================
CARDCOM_TERMINAL=1000
CARDCOM_USERNAME=test
CARDCOM_API_NAME=test
CARDCOM_API_PASSWORD=test
CARDCOM_REDIRECT_URL=http://localhost:3000/api/payments/cardcom/callback

# ============================================================
# iCount — חשבוניות (sandbox)
# ============================================================
ICOUNT_COMPANY_ID=demo
ICOUNT_USERNAME=demo
ICOUNT_API_KEY=sandbox_key
ICOUNT_BASE_URL=https://api.icount.co.il/api/v3.php

# ============================================================
# Anthropic — AI לתשובות רבניות
# ============================================================
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096

# ============================================================
# Email — בפיתוח: MailHog על localhost:1025
# ============================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="קייטרינג טעימים <noreply@catering-taamim.test>"
SMTP_SECURE=false

# SendGrid — מושבת בפיתוח (משתמשים ב-MailHog)
SENDGRID_API_KEY=SG.test-not-used-in-dev
SENDGRID_FROM_EMAIL=noreply@catering-taamim.test

# ============================================================
# S3 / Object storage — בפיתוח: MinIO על localhost:9000
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=catering-uploads
S3_ACCESS_KEY=catering
S3_SECRET_KEY=dev_password_change_in_prod
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/catering-uploads

# Cloudflare R2 — תואם S3, מושבת בפיתוח
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=catering
R2_SECRET_ACCESS_KEY=dev_password_change_in_prod
R2_BUCKET=catering-uploads

# ============================================================
# SMS — לא פעיל בפיתוח
# ============================================================
SMS4FREE_KEY=dev-placeholder
SMS4FREE_USER=dev-placeholder
SMS4FREE_PASS=dev-placeholder
SMS_SENDER=DEV-CATER

# ============================================================
# טלפוניה (IP Sales / NLPearl / OpenAI Realtime)
# ============================================================
IPSALES_BASE_URL=https://app.ipsales.co.il/api/v1
IPSALES_API_KEY=dev-placeholder
NLPEARL_API_KEY=dev-placeholder
OPENAI_API_KEY=sk-replace-with-real-key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ============================================================
# Feature flags / debug
# ============================================================
ENABLE_PLAYGROUND=true
ENABLE_QUERY_LOGGING=true
ENABLE_TRACE=false
DISABLE_RATE_LIMIT=true
DEMO_MODE=true

# ============================================================
# Multi-tenant
# ============================================================
DEFAULT_TENANT=demo
TENANT_RESOLUTION=subdomain  # subdomain | header | path

# ============================================================
# Observability — מושבת בפיתוח
# ============================================================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=false

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000
