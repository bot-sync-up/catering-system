# Public site URL (used in SEO, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://example.co.il
SITE_URL=https://example.co.il

# CRM webhook — receives leads from /api/contact
CRM_WEBHOOK_URL=
CRM_WEBHOOK_TOKEN=

# Mail webhook — used by reminder cron
MAIL_WEBHOOK_URL=
MAIL_WEBHOOK_TOKEN=

# Cron secret — header check on /api/contracts/reminders/run
CRON_SECRET=

# Cloudflare R2 — contract PDF storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=contracts
R2_PUBLIC_BASE_URL=

# DocuSign (optional, if signatureProvider=docusign)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=
