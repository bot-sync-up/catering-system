# Privacy Portal - מתאר תיקון 13 לחוק הגנת הפרטיות
DATABASE_URL="postgresql://privacy:privacy@localhost:5432/privacy_portal?schema=public"
REDIS_URL="redis://localhost:6379"

# SMTP / Email verification
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@syncup.co.il"
SMTP_PASS="changeme"
EMAIL_FROM="פורטל פרטיות <privacy@syncup.co.il>"

# Public base URL לקישורי double opt-in
PUBLIC_BASE_URL="https://privacy.syncup.co.il"

# סוד לחתימת טוקנים
TOKEN_SECRET="replace-with-32-bytes-random"

# יעדים לפנייה לרשם להגנת הפרטיות (אגף ת"ר)
DPO_EMAIL="dpo@syncup.co.il"
