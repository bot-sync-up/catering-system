default_platform(:ios)

PROJECT = "Catering.xcodeproj"
SCHEME = "Catering"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Run unit tests"
  lane :test do
    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      devices: ["iPhone 15"],
      clean: true
    )
  end

  desc "Build & upload to TestFlight"
  lane :beta do
    increment_build_number(xcodeproj: PROJECT)
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      configuration: "Release",
      clean: true
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "גרסה חדשה של Catering — נא לבדוק"
    )
  end

  desc "Release to App Store"
  lane :release do
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      configuration: "Release"
    )
    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end
end
