{
  "name": "finance-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Hebrew RTL financial documents system: Quote→Order→Invoice→Receipt with installments, aging, reminders (Email/SMS/WhatsApp), auto-freeze, postdated checks, RBAC.",
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "worker": "tsx src/jobs/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bullmq": "^5.34.0",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "pdfkit": "^0.15.0",
    "twilio": "^5.2.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.4",
    "prisma": "5.22.0",
    "tsx": "^4.16.2",
    "typescript": "5.6.3",
    "vitest": "^2.1.8"
  }
}
