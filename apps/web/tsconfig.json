{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@catering/ui": ["../../packages/ui/src"],
      "@catering/api": ["../../packages/api/src"],
      "@catering/db": ["../../packages/db/src"],
      "@catering/auth": ["../../packages/auth/src"],
      "@catering/utils": ["../../packages/utils/src"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
