{
  "name": "marketing-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing + Campaigns + Chatbot platform (RTL Hebrew)",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:server\" \"pnpm:dev:client\"",
    "dev:server": "pnpm --filter server run dev",
    "dev:client": "pnpm --filter client run dev",
    "build": "pnpm --filter server run build && pnpm --filter client run build",
    "start": "pnpm --filter server run start",
    "db:migrate": "pnpm --filter server run db:migrate",
    "db:generate": "pnpm --filter server run db:generate"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "_workspacesRemoved": [
    "server",
    "client"
  ]
}
