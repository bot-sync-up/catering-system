{
  "name": "marketing-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing + Campaigns + Chatbot platform (RTL Hebrew)",
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "start": "npm --workspace server run start",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:generate": "npm --workspace server run db:generate"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
