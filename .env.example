# ============================================================
# מערכת קייטרינג - משתני סביבה מאוחדים
# העתק ל-.env.local ומלא ערכים אמיתיים. אל תעלה ל-git!
# ============================================================

# -------- General --------
NODE_ENV=development
TZ=Asia/Jerusalem
APP_URL=http://localhost:3007

# -------- Database (02) --------
DATABASE_URL=postgresql://catering:catering@localhost:5432/catering?schema=public
DATABASE_SHADOW_URL=postgresql://catering:catering@localhost:5432/catering_shadow
DATABASE_POOL_SIZE=10

# -------- Redis / Queue (01) --------
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_PREFIX=catering

# -------- Auth (03) --------
JWT_SECRET=change-me-in-prod-min-32-chars-long-xxxxxxxxxx
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change-me-in-prod-min-32-chars-long-xxxxxxxxxx
NEXTAUTH_URL=http://localhost:3007
SESSION_COOKIE_NAME=catering_session
BCRYPT_ROUNDS=12

# -------- Audit (04) --------
AUDIT_LOG_LEVEL=info
AUDIT_RETENTION_DAYS=365

# -------- Cardcom (19) --------
CARDCOM_TERMINAL=0000000
CARDCOM_USERNAME=
CARDCOM_API_PASSWORD=
CARDCOM_API_URL=https://secure.cardcom.solutions/api/v11
CARDCOM_WEBHOOK_SECRET=

# -------- iCount (18) --------
ICOUNT_COMPANY_ID=
ICOUNT_USERNAME=
ICOUNT_PASSWORD=
ICOUNT_API_URL=https://api.icount.co.il/api/v3.php

# -------- OCR / AI (12) --------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
GOOGLE_VISION_KEY=

# -------- Email / SendGrid (23) --------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@catering.example.co.il
SENDGRID_FROM_NAME="Catering System"

# -------- SMS / Twilio (23) --------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_SMS_WEBHOOK=

# -------- WhatsApp Business (23) --------
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# -------- Storage / R2 (12, 17, 25) --------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=catering-uploads
R2_PUBLIC_URL=https://uploads.catering.example.co.il
S3_REGION=auto

# -------- Maps & Logistics (14, 21) --------
GOOGLE_MAPS_API_KEY=
WAZE_API_KEY=

# -------- Mobile / Expo (25) --------
EXPO_PROJECT_ID=85108f26-64c0-4dc2-b26c-26c1b76afb95
EXPO_PUBLIC_API_URL=http://localhost:3007/api

# -------- BI (22) --------
METABASE_URL=http://localhost:3033
METABASE_SECRET_KEY=

# -------- Misc --------
LOG_LEVEL=info
SENTRY_DSN=
RATE_LIMIT_PER_MINUTE=120
