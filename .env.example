# === Catering System — Environment Variables ===
# העתק קובץ זה ל-.env והזן את הערכים האמיתיים

# Database
DATABASE_URL=postgres://user:password@localhost:5432/catering
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=__REPLACE_WITH_LONG_RANDOM_STRING__
SESSION_SECRET=__REPLACE_WITH_LONG_RANDOM_STRING__

# OpenAI
OPENAI_API_KEY=sk-__REPLACE__
OPENAI_REALTIME_API_KEY=sk-__REPLACE__

# Google
GOOGLE_GEMINI_API_KEY=__REPLACE__
GOOGLE_OAUTH_CLIENT_ID=__REPLACE__
GOOGLE_OAUTH_CLIENT_SECRET=__REPLACE__

# Israeli Tax Integrations
ICOUNT_API_TOKEN=__REPLACE__
ICOUNT_COMPANY_ID=__REPLACE__
GREEN_INVOICE_API_KEY=__REPLACE__
GREEN_INVOICE_API_SECRET=__REPLACE__

# SMS / WhatsApp
TWILIO_ACCOUNT_SID=__REPLACE__
TWILIO_AUTH_TOKEN=__REPLACE__
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Israeli SMS (Telcell)
TELCELL_USER=__REPLACE__
TELCELL_PASSWORD=__REPLACE__

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=__REPLACE__
SMTP_PASS=__REPLACE__

# Payment Gateways
PAYPLUS_API_KEY=__REPLACE__
PAYPLUS_SECRET_KEY=__REPLACE__
TRANZILA_TERMINAL=__REPLACE__
TRANZILA_PASSWORD=__REPLACE__

# IPSales PBX
IPSALES_API_URL=https://app.ipsales.co.il/api
IPSALES_API_KEY=__REPLACE__

# AWS S3 (file storage)
AWS_ACCESS_KEY_ID=__REPLACE__
AWS_SECRET_ACCESS_KEY=__REPLACE__
AWS_S3_BUCKET=catering-uploads
AWS_REGION=eu-central-1

# Sentry (errors)
SENTRY_DSN=__REPLACE__

# App
NODE_ENV=production
APP_URL=https://app.catering.example.com
PORT=3000
