# ============================================
# Application
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
PORTAL_URL=http://localhost:3001
PUBLIC_SITE_URL=http://localhost:3002

# ============================================
# Database (Postgres 16)
# ============================================
DATABASE_URL=postgresql://aneh:aneh_dev_password@localhost:5432/aneh_hashoel
POSTGRES_USER=aneh
POSTGRES_PASSWORD=aneh_dev_password
POSTGRES_DB=aneh_hashoel

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================
# Auth
# ============================================
AUTH_SECRET=replace_with_random_64_char_string
AUTH_TRUST_HOST=true
JWT_SECRET=replace_with_random_64_char_string
JWT_EXPIRES_IN=7d

# ============================================
# Storage (Cloudflare R2)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aneh-hashoel
R2_PUBLIC_URL=https://cdn.example.com

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aneh-hashoel.org.il

# ============================================
# BullMQ
# ============================================
QUEUE_PREFIX=aneh
QUEUE_CONCURRENCY=5

# ============================================
# Public Next.js vars
# ============================================
NEXT_PUBLIC_APP_NAME=ענה את השואל
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SUPPORT_EMAIL=support@aneh-hashoel.org.il
