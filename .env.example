# ========== הגדרות סביבה — ענה את השואל ==========
# העתיקו את הקובץ ל-.env ומלאו ערכים אמיתיים
NODE_ENV=development

# ---------- אפליקציה ----------
APP_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3002
CUSTOMER_PORTAL_URL=http://localhost:3001

# ---------- Postgres 16 ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aneh
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aneh

# ---------- Redis / BullMQ ----------
REDIS_URL=redis://localhost:6379

# ---------- אימות (JWT) ----------
AUTH_SECRET=replace-me-with-a-32-char-random-string
JWT_ISSUER=aneh-hashoel
JWT_AUDIENCE=aneh-hashoel-clients

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aneh-hashoel
R2_PUBLIC_URL=https://media.example.com

# ---------- אינטגרציות ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# ---------- Mobile (Expo) ----------
EXPO_PUBLIC_API_URL=http://localhost:3000
