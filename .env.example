# ============================================================
# Catering Monorepo — Unified .env.example
# נוצר אוטומטית ממיזוג של 28 worktrees
# ============================================================

# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database (Postgres) ---
DATABASE_URL=postgresql://user:password@localhost:5432/catering
DIRECT_URL=postgresql://user:password@localhost:5432/catering

# --- Redis (queues, cache) ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_SECRET=replace-me-with-strong-random
NEXTAUTH_SECRET=replace-me-with-strong-random
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=replace-me-with-strong-random
AUDIT_RETENTION_DAYS=2555

# --- 2FA / SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TOTP_ISSUER=Catering

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Catering

# --- WhatsApp (Twilio / WaBA) ---
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM=

# --- AI (Claude / Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Israeli payments / accounting ---
ICOUNT_API_TOKEN=
ICOUNT_COMPANY_ID=
CARDCOM_TERMINAL=
CARDCOM_USERNAME=
CARDCOM_API_KEY=

# --- OCR / Files ---
OCR_PROVIDER=tesseract
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1
S3_ENDPOINT=

# --- Mobile (Expo) ---
EXPO_PROJECT_ID=
EAS_PROJECT_ID=

# --- Feature flags ---
FEATURE_BI_ENABLED=true
FEATURE_OCR_ENABLED=true
FEATURE_2FA_REQUIRED=false

# --- Public site / Marketing ---
PUBLIC_SITE_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
