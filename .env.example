# ─────────────────────────────────────────────────────────────
# Catering System — .env.example
# העתק לקובץ .env ומלא את הערכים האמיתיים.
# אל תעלה .env אמיתי ל-Git!
# ─────────────────────────────────────────────────────────────

# Node / App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_NAME=Catering System

# ────── Database ──────
DATABASE_URL=postgresql://catering:catering@localhost:5432/catering_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ────── Redis / Queue ──────
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=catering

# ────── Auth ──────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
BCRYPT_ROUNDS=12

# ────── חשבוניות ישראליות — iCount ──────
ICOUNT_COMPANY_ID=YOUR_ICOUNT_COMPANY_ID
ICOUNT_USERNAME=YOUR_ICOUNT_USERNAME
ICOUNT_PASSWORD=YOUR_ICOUNT_PASSWORD
ICOUNT_API_KEY=GET_FROM_ICOUNT

# ────── סליקת אשראי — CardCom ──────
CARDCOM_TERMINAL=GET_FROM_CARDCOM
CARDCOM_USERNAME=GET_FROM_CARDCOM
CARDCOM_API_KEY=GET_FROM_CARDCOM

# ────── AI Providers ──────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME
GOOGLE_AI_API_KEY=CHANGE_ME

# ────── Voice / Telephony ──────
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+972XXXXXXXXX
IPSALES_API_KEY=GET_FROM_IPSALES
IPSALES_WEBHOOK_SECRET=CHANGE_ME

# ────── Email — SendGrid ──────
SENDGRID_API_KEY=GET_FROM_SENDGRID
EMAIL_FROM=no-reply@catering-system.co.il

# ────── Object Storage — Cloudflare R2 ──────
R2_ACCESS_KEY=GET_FROM_CLOUDFLARE
R2_SECRET_KEY=GET_FROM_CLOUDFLARE
R2_BUCKET=catering-prod
R2_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com

# ────── Monitoring / Observability ──────
SENTRY_DSN=
LOGTAIL_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ────── Feature Flags ──────
FEATURE_VOICE_ORDERING=true
FEATURE_AI_MENU=true
FEATURE_MULTI_TENANT=false
