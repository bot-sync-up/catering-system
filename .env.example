# =============================================================================
# Catering Monorepo - דוגמה ל-.env מאוחד
# =============================================================================
# העתק לקובץ .env (לפיתוח) או .env.prod (לפרודקשן) ומלא את הערכים.
# אסור לעולם לדחוף קובץ .env מלא ל-git.
# =============================================================================

# -------------------- General --------------------
NODE_ENV=development
APP_ENV=development
TZ=Asia/Jerusalem

# -------------------- Database (Postgres + Prisma) --------------------
POSTGRES_DB=catering
POSTGRES_USER=catering
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql://catering:change_me_strong@localhost:5432/catering
DATABASE_REPLICA_URL=postgresql://catering:change_me_strong@localhost:5432/catering

# -------------------- Redis + BullMQ + Streams --------------------
REDIS_URL=redis://localhost:6379
REDIS_STREAMS_URL=redis://localhost:6379
REDIS_PASSWORD=change_me_strong
WORKER_CONCURRENCY=4
BULL_BOARD_USER=admin
BULL_BOARD_PASS=change_me

# -------------------- Auth / JWT / Sessions --------------------
JWT_ACCESS_SECRET=__GENERATE_WITH_openssl_rand_base64_48__
JWT_REFRESH_SECRET=__GENERATE_WITH_openssl_rand_base64_48__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
NEXTAUTH_SECRET=change_me_64_chars
NEXTAUTH_URL=http://localhost:3000
OTP_HMAC_SECRET=change_me_32_bytes
ENCRYPTION_KEY=change_me_32_bytes_base64
AES_KEY=change_me_32_bytes_base64

# -------------------- KMS / Secrets --------------------
KMS_KEY_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET=catering-uploads
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
BACKUP_ENCRYPTION_KEY=change_me_32_bytes

# -------------------- Israeli Tax + Invoicing --------------------
ICOUNT_API_TOKEN=
ICOUNT_COMPANY_ID=
CARDCOM_TERMINAL=
CARDCOM_USERNAME=
CARDCOM_API_NAME=
VAT_RATE=17

# -------------------- AI / LLM --------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -------------------- Email + SMS --------------------
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+972500000000

# -------------------- Observability --------------------
SENTRY_DSN=
DATADOG_API_KEY=
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_ROOT_URL=http://localhost/grafana
LOG_LEVEL=info

# -------------------- HTTP / CORS / Nginx --------------------
CORS_ORIGINS=http://localhost:3000
NGINX_SERVER_NAME=localhost
PORT_WEB=3000
PORT_API=4000
PORT_ORCHESTRATOR=4100
PORT_OCR=4200

# -------------------- Feature flags --------------------
FEATURE_PHASED_LAUNCH=true
FEATURE_DUAL_INVOICING=true
