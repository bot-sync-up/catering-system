# Audit Log System — Environment Configuration
# Copy to .env and fill values. Never commit .env.

# PostgreSQL connection — application user (used for normal queries)
DATABASE_URL="postgresql://app_user:CHANGE_ME@localhost:5432/aneh_hashoel?schema=public"

# PostgreSQL super user — used ONLY for migrations and creating triggers/policies.
# In production rotate and store in secret manager.
DATABASE_ADMIN_URL="postgresql://postgres:CHANGE_ME@localhost:5432/aneh_hashoel?schema=public"

# JWT secret for API authentication — minimum 32 random bytes
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_BYTES"
JWT_EXPIRES_IN="12h"

# App
PORT=4000
NODE_ENV=development

# Audit retention — 7 years (in days). Used by archival job; rows are NEVER deleted in-place.
AUDIT_RETENTION_DAYS=2555

# Tenant filter default (multi-tenant). For single-tenant deployments leave blank.
DEFAULT_TENANT_ID=""
