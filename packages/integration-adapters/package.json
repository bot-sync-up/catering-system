{
  "name": "@catering/integration-adapters",
  "version": "0.1.0",
  "description": "Adapters בין שירותי הפלטפורמה - CRM, Finance, Orders, Kitchen, Logistics, iCount, CardCom, Inventory, HR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@catering/event-bus": "workspace:*",
    "ioredis": "^5.4.2",
    "pino": "^9.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/uuid": "^9.0.8",
    "typescript": "5.6.3",
    "vitest": "^2.1.8"
  }
}
