{
  "name": "@catering/adapter-wiring",
  "version": "0.1.0",
  "description": "חיווט adapters ל-EventBus - publishers בכל מודול + subscribers לכל ה-11 adapters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./publishers": {
      "types": "./dist/publishers/index.d.ts",
      "import": "./dist/publishers/index.js"
    },
    "./subscribers": {
      "types": "./dist/subscribers/index.d.ts",
      "import": "./dist/subscribers/index.js"
    }
  },
  "files": ["dist", "WIRING-MAP.md", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "tsx scripts/verify-wiring.ts",
    "inject": "tsx scripts/inject-publishers.ts"
  },
  "dependencies": {
    "@catering/event-bus": "workspace:*",
    "@catering/integration-adapters": "workspace:*",
    "ioredis": "^5.4.1",
    "pino": "^9.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0"
  }
}
