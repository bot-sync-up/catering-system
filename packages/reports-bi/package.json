{
  "name": "@aneh-hashoel/reports-bi",
  "version": "0.1.0",
  "description": "מנוע דוחות ו-BI לפלטפורמת 'ענה את השואל' — קייטרינג, אירועים ו-ERP",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "report:run": "tsx src/cli/run-report.ts",
    "scheduler:start": "tsx src/reports/scheduler.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.13.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "decimal.js": "^10.4.3",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.1",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8",
    "@sendgrid/mail": "^8.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.4",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0",
    "vitest-mock-extended": "^1.3.1"
  },
  "files": [
    "dist",
    "fonts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  }
