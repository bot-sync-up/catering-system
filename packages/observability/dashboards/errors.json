{
  "uid": "errors",
  "title": "Errors — HTTP 5xx / Exceptions / Failed jobs",
  "tags": ["errors", "incidents"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "Asia/Jerusalem",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "5xx rate (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed jobs / min",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(queue_jobs_total{result=\"failed\"}[5m])) * 60"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Payment failures (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(payment_attempts_total{result!=\"success\"}[5m])) * 60"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active alerts",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\"})" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP errors by route",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (route, status_code) (rate(http_requests_total{status_code=~\"[45]..\"}[1m]))",
          "legendFormat": "{{ route }} {{ status_code }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent errors (Loki)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 12 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=~\".+\"} | json | level=\"error\""
        }
      ]
    }
  ]
}
