{
  "uid": "business",
  "title": "Business — Orders / Revenue / Payments / OCR / Delivery",
  "tags": ["business", "kpi"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "Asia/Jerusalem",
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(orders_total, tenant)",
        "includeAll": true,
        "multi": true
      },
      {
        "name": "channel",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(orders_total, channel)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "סך הזמנות (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(orders_total{tenant=~\"$tenant\",channel=~\"$channel\"}[24h]))",
          "legendFormat": "orders"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "הכנסות (24h, ₪)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(revenue_total_cents{tenant=~\"$tenant\",channel=~\"$channel\",currency=\"ILS\"}[24h])) / 100",
          "legendFormat": "revenue"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyILS", "decimals": 0 } }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Payment success rate (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(payment_attempts_total{result=\"success\"}[5m])) / sum(rate(payment_attempts_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "OCR accuracy",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(ocr_accuracy)" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "הזמנות לפי ערוץ",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (channel) (rate(orders_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{ channel }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "הכנסה (₪/דקה)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(revenue_total_cents{currency=\"ILS\"}[1m])) * 60 / 100",
          "legendFormat": "ILS/min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyILS" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Payment attempts לפי תוצאה",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (result) (rate(payment_attempts_total[1m]))",
          "legendFormat": "{{ result }}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Delivery on-time vs late",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (result) (rate(delivery_on_time_total[5m]))",
          "legendFormat": "{{ result }}"
        }
      ]
    }
  ]
}
