{
  "uid": "system",
  "title": "System — HTTP / DB / Queue / SSE",
  "tags": ["system", "red", "use"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "Asia/Jerusalem",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_request_duration_seconds_count, service)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP requests/sec (לפי status)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_requests_total{service=~\"$service\"}[1m]))",
          "legendFormat": "{{ status_code }}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP latency p50/p95/p99",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DB query duration p95 (לפי operation)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ operation }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Queue depth (waiting)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "queue_depth{state=\"waiting\"}",
          "legendFormat": "{{ queue }}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SSE connections",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (endpoint) (sse_connections)",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Node memory (heap used)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (service) (node_nodejs_heap_size_used_bytes)",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
