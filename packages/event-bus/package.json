{
  "name": "@catering/event-bus",
  "version": "0.1.0",
  "description": "Type-safe BullMQ-based event bus עם תמיכה ב-saga coordination",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./saga": {
      "types": "./dist/saga/index.d.ts",
      "import": "./dist/saga/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.7.0",
    "ioredis": "^5.4.1",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.7"
  }
}
