{
  "name": "@aneh/seed-data",
  "version": "0.1.0",
  "private": true,
  "description": "נתוני seed עבריים ריאליסטיים לפלטפורמת ענה את השואל / קייטרינג טעימים",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "seed": "tsx prisma/seed.ts",
    "seed:small": "tsx prisma/seed.ts --tenant=demo --scale=small",
    "seed:medium": "tsx prisma/seed.ts --tenant=demo --scale=medium",
    "seed:large": "tsx prisma/seed.ts --tenant=demo --scale=large",
    "reset": "tsx src/reset.ts --tenant=demo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
