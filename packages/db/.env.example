# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://aneh_user:aneh_pass@localhost:5432/aneh_hashoel?schema=public"

# Shadow database (used by `prisma migrate dev`) — optional
SHADOW_DATABASE_URL="postgresql://aneh_user:aneh_pass@localhost:5432/aneh_hashoel_shadow?schema=public"
