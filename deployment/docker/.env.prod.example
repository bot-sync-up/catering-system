# =====================================================================
# Production environment — copy to ../secrets/.env.prod and FILL VALUES.
# NEVER commit the real file. Provision via Vault / Doppler / SOPS.
# =====================================================================
DOMAIN=example.com
NODE_ENV=production

# Database
POSTGRES_USER=app
POSTGRES_PASSWORD=__SET_ME__
POSTGRES_DB=appdb
DATABASE_URL=postgresql://app:__SET_ME__@postgres:5432/appdb?schema=public&connection_limit=20

# Redis
REDIS_PASSWORD=__SET_ME__
REDIS_URL=redis://:__SET_ME__@redis:6379

# Auth
JWT_SECRET=__SET_ME__
JWT_REFRESH_SECRET=__SET_ME__
AES_KEY=__SET_ME__   # 32 bytes base64
NEXTAUTH_URL=https://www.example.com
NEXTAUTH_SECRET=__SET_ME__

# Payments
ICOUNT_API_TOKEN=__SET_ME__
ICOUNT_COMPANY_ID=__SET_ME__
CARDCOM_TERMINAL=__SET_ME__
CARDCOM_USERNAME=__SET_ME__
CARDCOM_API_PASSWORD=__SET_ME__

# Messaging
WHATSAPP_TOKEN=__SET_ME__
WHATSAPP_PHONE_ID=__SET_ME__
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=__SET_ME__
SMTP_PASS=__SET_ME__

# Storage / CDN
S3_ENDPOINT=https://r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=app-prod
S3_ACCESS_KEY=__SET_ME__
S3_SECRET_KEY=__SET_ME__

# Observability
SENTRY_DSN=https://__SET_ME__@sentry.io/__SET_ME__
SENTRY_AUTH_TOKEN=__SET_ME__
GRAFANA_ADMIN_PASSWORD=__SET_ME__
BOARD_USERNAME=ops
BOARD_PASSWORD=__SET_ME__
LOG_LEVEL=info

# Feature flags
RATE_LIMIT_RPS=30
ENABLE_AUDIT_LOG=true
