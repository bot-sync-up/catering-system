{
  "uid": "business-kpi",
  "title": "Business KPIs",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "tags": ["business"],
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "Orders / minute",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(orders_created_total[1m])) * 60" }],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2, "title": "Revenue (ILS) — last 24h",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(revenue_ils_total[24h]))" }],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "currencyILS" } }
    },
    {
      "id": 3, "title": "Conversion (paid / cart)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(orders_paid_total[1h])) / sum(increase(cart_created_total[1h]))" }],
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 4, "title": "Payment success rate",
      "type": "timeseries",
      "targets": [{
        "expr": "sum(rate(payment_attempts_total{status=\"success\"}[5m])) / sum(rate(payment_attempts_total[5m]))"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5, "title": "AOV (avg order value)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(revenue_ils_total[1h])) / sum(increase(orders_paid_total[1h]))" }],
      "fieldConfig": { "defaults": { "unit": "currencyILS" } },
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 }
    },
    {
      "id": 6, "title": "Active sessions",
      "type": "stat",
      "targets": [{ "expr": "sum(session_active_users)" }],
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 }
    },
    {
      "id": 7, "title": "Top failure reasons",
      "type": "table",
      "targets": [{ "expr": "topk(10, sum by (reason)(rate(payment_attempts_total{status=\"failed\"}[1h])))" }],
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 }
    }
  ]
}
