# pnpm monorepo config — תיקוני קונפליקטים אוטומטיים
auto-install-peers=true
strict-peer-dependencies=false
prefer-workspace-packages=true
shamefully-hoist=false
resolution-mode=highest
link-workspace-packages=true
save-workspace-protocol=rolling
recursive-install=true
verify-store-integrity=false
# Prevent corepack/Yarn confusion
package-manager-strict=false
# Reduce peer warnings for React 18/19 hybrid
@aneh:registry=https://registry.npmjs.org/
@catering:registry=https://registry.npmjs.org/
@security-fixes:registry=https://registry.npmjs.org/
@syncup:registry=https://registry.npmjs.org/
@field-ops:registry=https://registry.npmjs.org/
@invoice-ocr:registry=https://registry.npmjs.org/
@integrations:registry=https://registry.npmjs.org/
@aneh-hashoel:registry=https://registry.npmjs.org/
@marketing:registry=https://registry.npmjs.org/
