# Copy to .env.prod and fill in. NEVER commit the filled version.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_strong

REDIS_PASSWORD=change_me_strong

JWT_ACCESS_SECRET=__GENERATE_WITH_openssl_rand_base64_48__
JWT_REFRESH_SECRET=__GENERATE_WITH_openssl_rand_base64_48__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AES_KEY=change_me_32_bytes_base64

CORS_ORIGINS=https://example.com,https://www.example.com
NGINX_SERVER_NAME=example.com www.example.com

GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_ROOT_URL=https://example.com/grafana

WORKER_CONCURRENCY=4

# Backups (R2 / S3)
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=app-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=
BACKUP_ENCRYPTION_KEY=change_me_32_bytes
