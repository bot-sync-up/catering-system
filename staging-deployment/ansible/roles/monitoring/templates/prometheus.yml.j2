global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    env: staging
    project: catering

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

rule_files:
  - "alerts/*.yml"

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: node
    static_configs:
      - targets: ["host.docker.internal:9100"]
        labels:
          instance: staging-app-1

  - job_name: cadvisor
    static_configs:
      - targets: ["cadvisor:8080"]

  - job_name: docker_engine
    static_configs:
      - targets: ["host.docker.internal:9323"]

  - job_name: nginx
    static_configs:
      - targets: ["host.docker.internal:9113"] # nginx-prometheus-exporter

  - job_name: app_api
    metrics_path: /metrics
    static_configs:
      - targets: ["host.docker.internal:4000"]
        labels:
          service: api

  - job_name: app_portal
    metrics_path: /metrics
    static_configs:
      - targets: ["host.docker.internal:3100"]
        labels:
          service: portal
