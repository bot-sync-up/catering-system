apiVersion: 1

datasources:
  - name: Prometheus-Staging
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: true
    editable: false
    jsonData:
      timeInterval: "15s"

  - name: Loki-Staging
    type: loki
    access: proxy
    url: http://loki:3100
    editable: false
    jsonData:
      maxLines: 1000

deleteDatasources:
  - name: TestData
    orgId: 1
