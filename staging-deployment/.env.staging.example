###############################################################################
# .env.staging.example
# העתיקו ל-.env.staging והחליפו את כל ה-SECRETS_PLACEHOLDER לערכים אמיתיים.
# הקובץ האמיתי לא נכנס ל-git.
###############################################################################

# ───── General ───────────────────────────────────────────────────────────────
NODE_ENV=staging
APP_ENV=staging
LOG_LEVEL=info
TAG=TAG_PLACEHOLDER

PUBLIC_BASE_URL=https://staging.catering.co.il
API_BASE_URL=https://api.staging.catering.co.il
PORTAL_BASE_URL=https://portal.staging.catering.co.il
ADMIN_BASE_URL=https://admin.staging.catering.co.il
MEDIA_BASE_URL=https://media.staging.catering.co.il

# ───── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=SECRETS_PLACEHOLDER_DB_URL
DATABASE_POOL_MAX=20
DATABASE_SSL=require

# ───── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=SECRETS_PLACEHOLDER_REDIS_URL
REDIS_TLS=true

# ───── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=SECRETS_PLACEHOLDER_JWT_SECRET
JWT_TTL=4h
SESSION_SECRET=SECRETS_PLACEHOLDER_SESSION_SECRET
COOKIE_DOMAIN=.staging.catering.co.il
COOKIE_SECURE=true

# ───── Stripe (sandbox) ──────────────────────────────────────────────────────
STRIPE_API_KEY=SECRETS_PLACEHOLDER_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=SECRETS_PLACEHOLDER_STRIPE_WEBHOOK
STRIPE_MODE=test

# ───── Cloudflare R2 ─────────────────────────────────────────────────────────
R2_ACCOUNT_ID=CHANGE_ME_CF_ACCOUNT_ID
R2_BUCKET_UPLOADS=catering-staging-uploads
R2_BUCKET_BACKUPS=catering-staging-backups
R2_BUCKET_MEDIA=catering-staging-media
R2_ACCESS_KEY_ID=SECRETS_PLACEHOLDER_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=SECRETS_PLACEHOLDER_R2_SECRET_KEY
R2_PUBLIC_BASE_URL=https://media.staging.catering.co.il

# ───── Email ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=SECRETS_PLACEHOLDER_SMTP_USER
SMTP_PASSWORD=SECRETS_PLACEHOLDER_SMTP_PASS
SMTP_FROM=staging@catering.co.il

# ───── SMS (Twilio sandbox) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=SECRETS_PLACEHOLDER_TWILIO_SID
TWILIO_AUTH_TOKEN=SECRETS_PLACEHOLDER_TWILIO_TOKEN
TWILIO_FROM=+15005550006

# ───── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=SECRETS_PLACEHOLDER_SENTRY_DSN
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.2
SLACK_WEBHOOK_URL=SECRETS_PLACEHOLDER_SLACK_WEBHOOK

# ───── Feature flags ─────────────────────────────────────────────────────────
FEATURE_DEBUG_TOOLBAR=true
FEATURE_FAKE_PAYMENTS=true
FEATURE_RATE_LIMIT=true
FEATURE_AUDIT_LOG=true
