# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketing
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=change_me_in_production
PUBLIC_BASE_URL=http://localhost:4000

# --- SendGrid ---
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=marketing@example.co.il
SENDGRID_FROM_NAME=Marketing

# --- 019 SMS ---
SMS_019_USER=user
SMS_019_PASSWORD=password
SMS_019_SOURCE=Marketing

# --- Twilio (fallback) ---
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_FROM=+1xxxx

# --- WhatsApp Cloud API ---
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_VERIFY_TOKEN=verify_me
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxxx

# --- Anthropic (Chatbot) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-opus-4-7

# --- Ad platforms ---
META_ACCESS_TOKEN=xxxxx
META_AD_ACCOUNT_ID=act_xxxxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxx
GOOGLE_ADS_CUSTOMER_ID=xxxxx
GOOGLE_ADS_REFRESH_TOKEN=xxxxx
