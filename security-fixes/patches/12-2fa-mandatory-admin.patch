# 4) הוספת dependency:
#    npm i otplib
# 5) helpers (לדוגמה — להניח ב-server/src/services/totp.ts):
# ----------------------------------------------------------------
+import { authenticator } from "otplib";
+import crypto from "node:crypto";
+
+authenticator.options = { window: 1 }; // ±30 שניות
+
+export function generateTotpSecret(): string {
+  return authenticator.generateSecret(32);
+}
+
+export function verifyTotp(secret: string, code: string): boolean {
+  return authenticator.verify({ token: code, secret });
+}
+
+export function generateBackupCodes(count = 10): string[] {
+  return Array.from({ length: count }, () =>
+    crypto.randomBytes(5).toString("hex").toUpperCase().match(/.{1,5}/g)!.join("-"),
+  );
+}
+
+export async function consumeBackupCode(userId: string, code: string): Promise<boolean> {
+  const user = await prisma.user.findUnique({ where: { id: userId } });
+  if (!user) return false;
+  const idx = user.twoFactorBackupCodes.indexOf(code.toUpperCase().trim());
+  if (idx < 0) return false;
+  const next = [...user.twoFactorBackupCodes];
+  next.splice(idx, 1);
+  await prisma.user.update({ where: { id: userId }, data: { twoFactorBackupCodes: next } });
+  return true;
+}
