# תיקון #14 - Marketing XSS: DOMPurify + escape merge fields
# קובץ יעד: agent-a7f6f8c320f0b1219/marketing-platform/server/src/services/templating.ts
# בעיה:
#   1) renderTemplate מחליף {{firstName}} ב-vars ללא escape → אם
#      קלט המשתמש כולל HTML/JS, הוא ייכלל ב-email/landing → XSS.
#   2) תוכן ה-template עצמו (מ-DB) לא עובר sanitization → מנהל זדוני /
#      compromised account יכול להחדיר <script>.
# פתרון:
#   1) להחיל escapeHtml על כל merge field לפני ההחדרה.
#   2) להחיל DOMPurify על תוצאת ה-template כתוצר סופי.
#   3) אופציית allowRawHtml=true רק עבור שדות שמוגדרים מראש (raw_*).

--- a/agent-a7f6f8c320f0b1219/marketing-platform/server/src/services/templating.ts
+++ b/agent-a7f6f8c320f0b1219/marketing-platform/server/src/services/templating.ts
@@ -1,10 +1,49 @@
+import createDOMPurify from 'isomorphic-dompurify';
+
+const DOMPurify = createDOMPurify;
+
+function escapeHtml(s: string): string {
+  return s
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&#39;');
+}
+
 /** Lightweight Mustache-like template engine. Supports {{var}} and {{var|default}}. */
-export function renderTemplate(tpl: string, vars: Record<string, any>): string {
-  return tpl.replace(/\{\{\s*([\w.]+)(?:\s*\|\s*([^}]+))?\s*\}\}/g, (_m, key, defaultVal) => {
-    const value = key.split('.').reduce((acc: any, k: string) => acc?.[k], vars);
-    if (value === undefined || value === null || value === '') {
-      return defaultVal !== undefined ? String(defaultVal).trim() : '';
-    }
-    return String(value);
-  });
+/**
+ * שיפור אבטחה:
+ *   - כל merge field עובר HTML-escape כברירת מחדל (מונע XSS).
+ *   - שדות שמתחילים ב-"raw_" מותר להם להכיל HTML, אבל הם עוברים DOMPurify.
+ *   - בסיום, התוצאה כולה עוברת DOMPurify כדי לסנן <script>/onerror שהושתלו
+ *     בתוכן ה-template עצמו.
+ */
+export function renderTemplate(
+  tpl: string,
+  vars: Record<string, unknown>,
+  opts: { allowRawTags?: boolean } = {},
+): string {
+  const replaced = tpl.replace(/\{\{\s*([\w.]+)(?:\s*\|\s*([^}]+))?\s*\}\}/g, (_m, key: string, defaultVal?: string) => {
+    const value = key.split('.').reduce<unknown>((acc, k) => (acc as Record<string, unknown> | undefined)?.[k], vars);
+    const raw =
+      value === undefined || value === null || value === ''
+        ? defaultVal !== undefined
+          ? String(defaultVal).trim()
+          : ''
+        : String(value);
+
+    // שדות שמתחילים ב-raw_ מותר להם להכיל HTML — עוברים sanitize בלבד.
+    if (key.startsWith('raw_')) {
+      return DOMPurify.sanitize(raw, {
+        ALLOWED_TAGS: ['b', 'i', 'em', 'strong', 'a', 'br', 'p', 'span', 'ul', 'ol', 'li'],
+        ALLOWED_ATTR: ['href', 'title', 'target', 'rel'],
+      });
+    }
+    // כל השאר — escape מלא.
+    return escapeHtml(raw);
+  });
+
+  // sanitize סופי על כל המסמך — כדי לטפל גם בתוכן template זדוני
+  return DOMPurify.sanitize(replaced, {
+    FORBID_TAGS: ['script', 'style', 'iframe', 'object', 'embed', 'form'],
+    FORBID_ATTR: ['onerror', 'onclick', 'onload', 'onmouseover', 'onfocus', 'onblur', 'onchange'],
+  });
 }


