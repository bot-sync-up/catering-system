# תיקון #7 - JWT_SECRET ב-finance-docs
# קובץ יעד: agent-a31b566159e7cc878/finance-docs/.env.example
# בעיה: ערך ברירת המחדל "change-me" — חולשת אבטחה קריטית.
#       אם דחפו כך לפרודקשן, ניתן לזייף JWTs ולקבל גישת admin.
# פתרון:
#   1) להחליף לערך אסור-לשימוש שגורם לאזהרה ולעצור boot.
#   2) להוסיף הוראת ייצור עם openssl rand -hex 32 (256-bit).
#   3) להוסיף JWT_REFRESH_SECRET ו-JWT_ACCESS_TTL (תיקון #11).

--- a/agent-a31b566159e7cc878/finance-docs/.env.example
+++ b/agent-a31b566159e7cc878/finance-docs/.env.example
@@ -1,6 +1,15 @@
 DATABASE_URL="postgresql://user:pass@localhost:5432/finance_docs?schema=public"
 REDIS_URL="redis://localhost:6379"
-JWT_SECRET="change-me"
+# ---------------------------------------------------------------
+# JWT secrets — חובה לייצר ערכים אקראיים חזקים.
+# ייצור:
+#   openssl rand -hex 32   # 256-bit (32 bytes hex)
+# אסור להשתמש בערך הברירת-מחדל מתחת — boot ייכשל אם לא הוחלף.
+# ---------------------------------------------------------------
+JWT_SECRET="REPLACE_WITH_openssl_rand_hex_32_OUTPUT"
+JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_openssl_rand_hex_32_OUTPUT"
+JWT_ACCESS_TTL="15m"
+JWT_REFRESH_TTL="7d"
 PORT=3000

 # VAT


