+authRouter.post("/refresh", async (req, res) => {
+  const refreshTokenCookie = req.cookies?.refreshToken;
+  if (!refreshTokenCookie) {
+    return res.status(401).json({ error: "אין refresh token" });
+  }
+  try {
+    const decoded = verifyRefreshToken(refreshTokenCookie);
+    // אימות שה-tokenId לא בוטל ב-DB:
+    const dbToken = await prisma.refreshToken.findUnique({
+      where: { tokenId: decoded.tokenId },
+    });
+    if (!dbToken || dbToken.revokedAt) {
+      return res.status(401).json({ error: "refresh token לא תקף" });
+    }
+    const user = await prisma.user.findUnique({ where: { id: decoded.userId } });
+    if (!user) return res.status(401).json({ error: "משתמש לא קיים" });
+    const access = signAccessToken({ userId: user.id, role: user.role });
+    return res.json({ accessToken: access });
+  } catch {
+    return res.status(401).json({ error: "refresh token לא תקף" });
+  }
+});
+
+authRouter.post("/logout", async (req, res) => {
+  const refreshTokenCookie = req.cookies?.refreshToken;
+  if (refreshTokenCookie) {
+    try {
+      const decoded = verifyRefreshToken(refreshTokenCookie);
+      await prisma.refreshToken.update({
+        where: { tokenId: decoded.tokenId },
+        data: { revokedAt: new Date() },
+      });
+    } catch { /* ignore */ }
+  }
+  res.clearCookie("refreshToken", { httpOnly: true, secure: true, sameSite: "strict" });
+  return res.status(204).end();
+});
